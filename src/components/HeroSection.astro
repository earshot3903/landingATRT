---
import { hero } from '../data/landingContent';
---

<section class="section-grid relative isolate overflow-hidden bg-white">
  <div class="mx-auto grid max-w-7xl gap-14 px-6 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-28">
    <div class="relative z-10">
      <div class="absolute -left-6 top-2 hidden h-24 w-1 rounded-full bg-[linear-gradient(180deg,var(--color-brand),rgba(44,125,160,0.18))] lg:block"></div>
      <span class="eyebrow hero-reveal" data-delay="0">{hero.badge}</span>
      <p class="mt-6 text-sm font-bold tracking-[0.18em] text-[var(--color-brand-strong)] uppercase hero-reveal" data-delay="120">
        Auto Transportes Refrigerados Torres
      </p>
      <h1 class="section-title hero-reveal mt-6 max-w-4xl text-5xl leading-[1.02] font-semibold text-[var(--color-ink)] md:text-6xl xl:text-7xl" data-delay="240">
        {hero.title}
      </h1>
      <p class="hero-reveal mt-6 max-w-2xl text-lg leading-8 text-[var(--color-muted)] md:text-xl" data-delay="360">
        {hero.subtitle}
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a
          href="#contacto"
          class="btn-primary px-7 py-4 text-base hero-reveal"
          data-delay="480"
        >
          {hero.primaryCta}
        </a>
        <a
          href="#ventajas"
          class="btn-secondary px-7 py-4 text-base hero-reveal"
          data-delay="520"
        >
          {hero.secondaryCta}
        </a>
      </div>

      <div class="hero-assurance mt-10 grid gap-5 border-t border-[var(--color-line)] pt-6 sm:grid-cols-3" data-stagger>
        {hero.proof.map((item, index) => (
          <div
            class="border-l-2 border-[var(--color-soft)] pl-4 text-sm leading-6 text-[var(--color-text)] hero-reveal"
            data-delay={560 + index * 80}
            data-stagger-item
          >
            {item}
          </div>
        ))}
      </div>
    </div>

    <div class="relative z-10 lg:pt-5">
      <div class="hero-visual reveal-scale" data-delay="180">
        <figure class="relative aspect-[4/5] overflow-hidden rounded-[2rem] bg-[var(--color-ink)] sm:aspect-[5/4] lg:aspect-[4/5]">
          <img
            src="/hero-camion-atrt.png"
            alt="Unidad refrigerada de Auto Transportes Refrigerados Torres"
            class="h-full w-full object-cover object-[88%_center]"
            width="1200"
            height="960"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(1,42,74,0.04)_28%,rgba(1,42,74,0.9)_100%)]"></div>

          <div class="absolute inset-x-5 top-5 flex items-start justify-between gap-4 md:inset-x-7 md:top-7">
            <div class="rounded-xl border border-white/30 bg-white/92 px-4 py-3 shadow-lg backdrop-blur-md">
              <img src="/Azul_Fuerte.png" alt="ATRT" class="h-9 w-auto object-contain md:h-11" />
            </div>
            <span class="rounded-full border border-white/25 bg-[rgba(1,42,74,0.68)] px-4 py-2 text-xs font-bold tracking-[0.16em] text-white uppercase backdrop-blur-md">
              En ruta
            </span>
          </div>

          <figcaption class="absolute inset-x-6 bottom-6 text-white md:inset-x-8 md:bottom-8">
            <p class="text-xs font-bold tracking-[0.22em] text-[var(--color-soft)] uppercase">Operacion refrigerada</p>
            <p class="mt-3 max-w-md font-['Sora'] text-2xl leading-tight font-semibold md:text-3xl">Operacion con visibilidad y respuesta</p>
            <p class="mt-3 max-w-lg text-sm leading-6 text-white/75 md:text-base">
              Auto Transportes Refrigerados Torres coordina trayectos con monitoreo, puntualidad y seguimiento operativo.
            </p>
          </figcaption>
        </figure>

        <div class="hero-proof-panel grid gap-px overflow-hidden rounded-[1.4rem] border border-[var(--color-line)] bg-[var(--color-line)] sm:grid-cols-2">
          <div class="bg-white p-5 md:p-6">
            <p class="text-xs font-bold tracking-[0.18em] text-[var(--color-muted)] uppercase">Monitoreo</p>
            <p class="mt-2 text-2xl font-semibold text-[var(--color-ink)]">24/7</p>
            <p class="mt-2 text-sm leading-6 text-[var(--color-muted)]">Seguimiento operativo continuo para trayectos activos.</p>
          </div>
          <div class="bg-white p-5 md:p-6">
            <p class="text-xs font-bold tracking-[0.18em] text-[var(--color-muted)] uppercase">Cumplimiento</p>
            <p class="mt-2 text-2xl font-semibold text-[var(--color-ink)]">Puntual</p>
            <p class="mt-2 text-sm leading-6 text-[var(--color-muted)]">Planeacion coordinada para ventanas de entrega comprometidas.</p>
          </div>
        </div>

        <div class="mt-5 border-l-2 border-[var(--color-brand)] pl-5 md:pl-6">
          <p class="text-xs font-bold tracking-[0.2em] text-[var(--color-brand)] uppercase">Compromiso ATRT</p>
          <h2 class="section-title mt-3 text-xl leading-tight font-semibold text-[var(--color-ink)] md:text-2xl">{hero.persuasiveTitle}</h2>
          <p class="mt-3 text-sm leading-6 text-[var(--color-muted)] md:text-base">{hero.persuasiveText}</p>
        </div>
      </div>
    </div>
  </div>
</section>
