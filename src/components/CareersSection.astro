---
import { careers, jobOpenings } from '../data/landingContent';
---

<section id="vacantes" class="relative z-10 mx-auto max-w-7xl px-6 py-18 lg:px-8 lg:py-24">
  <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr]">
    <div class="glass-card rounded-[2rem] p-8">
      <span class="eyebrow">Talento ATRT</span>
      <h2 class="section-title mt-6 text-4xl leading-tight font-semibold text-[var(--color-ink)] md:text-5xl">
        {careers.title}
      </h2>
      <p class="mt-6 text-lg leading-8 text-[var(--color-muted)]">{careers.subtitle}</p>

      <div class="mt-8 space-y-4 rounded-[1.5rem] border border-[var(--color-line)] bg-[var(--color-surface-alt)] p-5">
        <div>
          <p class="text-xs font-bold tracking-[0.18em] text-[var(--color-brand-strong)] uppercase">Ubicacion base</p>
          <p class="mt-2 text-base font-semibold text-[var(--color-ink)]">{careers.location}</p>
        </div>
        <div>
          <p class="text-xs font-bold tracking-[0.18em] text-[var(--color-brand-strong)] uppercase">Contacto de reclutamiento</p>
          <a href={`tel:+52${careers.contactPhone.replaceAll(' ', '')}`} class="mt-2 block text-base font-semibold text-[var(--color-ink)]">
            {careers.contactPhone}
          </a>
        </div>
      </div>

      <a href={`tel:+52${careers.contactPhone.replaceAll(' ', '')}`} class="btn-primary mt-8 px-7 py-4 text-base">
        {careers.ctaLabel}
      </a>
    </div>

    <div class="grid gap-5">
      {jobOpenings.map((job) => (
        <article class="glass-card rounded-[1.9rem] p-7">
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div>
              <p class="text-sm font-bold tracking-[0.18em] text-[var(--color-brand-strong)] uppercase">Vacante abierta</p>
              <h3 class="mt-3 text-2xl font-semibold text-[var(--color-ink)]">{job.title}</h3>
              <p class="mt-2 text-sm font-medium text-[var(--color-muted)]">{job.location}</p>
            </div>
            <a href={`tel:+52${careers.contactPhone.replaceAll(' ', '')}`} class="btn-secondary px-5 py-3 text-sm">
              Llamar para aplicar
            </a>
          </div>

          <p class="mt-5 text-base leading-7 text-[var(--color-muted)]">{job.summary}</p>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="rounded-[1.4rem] border border-[var(--color-line)] bg-white p-5">
              <p class="text-sm font-bold tracking-[0.16em] text-[var(--color-brand)] uppercase">Requisitos</p>
              <ul class="mt-4 space-y-3 text-sm leading-6 text-[var(--color-text)]">
                {job.requirements.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>

            <div class="rounded-[1.4rem] border border-[var(--color-line)] bg-white p-5">
              <p class="text-sm font-bold tracking-[0.16em] text-[var(--color-brand)] uppercase">Ofrecemos</p>
              <ul class="mt-4 space-y-3 text-sm leading-6 text-[var(--color-text)]">
                {job.benefits.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
