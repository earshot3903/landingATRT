---
import { navItems } from '../data/landingContent';
---

<header class="sticky top-0 z-50 border-b border-[var(--color-line)] bg-[rgba(255,255,255,0.8)] backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <a href="#" class="group flex items-center">
      <img
        src="/Negro.png"
        alt="ATRT - Auto Transportes Refrigerados Torres"
        class="h-14 w-auto object-contain transition duration-300 group-hover:-translate-y-0.5 group-hover:scale-[1.02] lg:h-25"
      />
    </a>

    <nav class="hidden items-center gap-7 text-sm text-[var(--color-muted)] lg:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="group relative py-2 font-medium tracking-[0.02em] transition duration-300 hover:text-[var(--color-ink)]"
        >
          <span>{item.label}</span>
          <span class="absolute inset-x-0 -bottom-0.5 h-0.5 origin-left scale-x-0 rounded-full bg-[var(--color-brand)] transition duration-300 group-hover:scale-x-100"></span>
        </a>
      ))}
    </nav>

    <a
      href="#contacto"
      class="btn-primary hidden px-5 py-3 text-sm transition duration-300 hover:shadow-[0_22px_42px_rgba(1,79,134,0.3)] lg:inline-flex"
    >
      Cotizar ahora
    </a>
  </div>
</header>
