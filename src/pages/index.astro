>
  <main>
    <Navbar />
    <HeroSection />
    <ValueStrip />
    <ServicesSection />
    <BenefitsSection />
    <MetricsSection />
    <TrustSection />
    <TestimonialsSection />
    <CareersSection />
    <FinalCtaSection />
    <Footer />
  </main>
</Layout>
