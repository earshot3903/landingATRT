---
import BenefitsSection from '../components/BenefitsSection.astro';
import CareersSection from '../components/CareersSection.astro';
import FinalCtaSection from '../components/FinalCtaSection.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import MetricsSection from '../components/MetricsSection.astro';
import Navbar from '../components/Navbar.astro';
import ServicesSection from '../components/ServicesSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import TrustSection from '../components/TrustSection.astro';
import ValueStrip from '../components/ValueStrip.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
