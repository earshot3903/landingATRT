---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Auto Transportes Refrigerados Torres | Transporte confiable de carga con control de temperatura',
	description = 'Soluciones empresariales de transporte refrigerado de Auto Transportes Refrigerados Torres, con monitoreo, seguridad operativa, puntualidad y atencion personalizada para clientes B2B.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#081a2c" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="bg-[var(--color-surface)] text-[var(--color-text)] antialiased">
		<div class="page-shell">
			<slot />
		</div>
		<script type="module" src="/scripts/animations.js"></script>
	</body>
</html>
